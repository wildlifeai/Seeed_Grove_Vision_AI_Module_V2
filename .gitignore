# ---------------------------
# DPD generated files
# ---------------------------

# Ignore everything inside output_case1_sec_wlcsp
we2_image_gen_local_dpd/output_case1_sec_wlcsp/**

# But keep the folder itself
!we2_image_gen_local_dpd/output_case1_sec_wlcsp/

# Keep the golden reference image
!we2_image_gen_local_dpd/output_case1_sec_wlcsp/output.img

# Ignore files in secureboot_tool
we2_image_gen_local_dpd/secureboot_tool/**/*.crt
we2_image_gen_local_dpd/secureboot_tool/**/*.txt
we2_image_gen_local_dpd/secureboot_tool/**/*.log

# Track all other subfolders normally (do not ignore their contents)
# No need to do anything else � they are tracked by default


